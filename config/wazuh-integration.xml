<integration>
  <name>webhook</name>

  <!-- n8n webhook URL -->
  <hook_url>http://YOUR-IP:5678/webhook/wazuh-alert</hook_url>

  <!-- Send only important alerts -->
  <level>7</level>

  <!-- OR use rule-based filtering -->
  <!-- <rule_id>100211,100212</rule_id> -->

  <!-- Send alert in JSON format -->
  <alert_format>json</alert_format>
</integration>
